// ブロック操作に関するツール群
// - ブロックの設置、破壊、情報取得、スキャンなどを行います。
//
// ここでは「参照ブロック」を使ってブロックを設置するなど、
// Mineflayer の実装上少し面倒な操作を扱います。
// 各ツールは外部（LLM 等）から安全に呼べるようにエラーハンドリングと
// 分かりやすいメッセージを返すことを優先しています。
import { z } from "zod";
import mineflayer from 'mineflayer';
import pathfinderPkg from 'mineflayer-pathfinder';
const { goals } = pathfinderPkg;
import { Vec3 } from 'vec3';
import minecraftData from 'minecraft-data';
import { ToolFactory } from '../tool-factory.js';
import { log } from '../logger.js';
import { coerceCoordinates } from './coordinate-utils.js';

type FaceDirection = 'up' | 'down' | 'north' | 'south' | 'east' | 'west';

interface FaceOption {
  direction: string;
  vector: Vec3;
}

export function registerBlockTools(factory: ToolFactory, getBot: () => mineflayer.Bot): void {
  // 指定位置にブロックを置くツール
  // 注意: ブロックを置くには参照ブロック（近隣）が必要になることが多いです。
  factory.registerTool(
    "place-block",
    "Place a block at the specified position",
    {
      x: z.coerce.number().describe("X coordinate"),
      y: z.coerce.number().describe("Y coordinate"),
      z: z.coerce.number().describe("Z coordinate"),
      faceDirection: z.enum(['up', 'down', 'north', 'south', 'east', 'west']).optional().describe("Direction to place against (default: 'down')")
    },
    async ({ x, y, z, faceDirection = 'down' }: { x: number, y: number, z: number, faceDirection?: FaceDirection }) => {
      ({ x, y, z } = coerceCoordinates(x, y, z));

      const bot = getBot();
      const placePos = new Vec3(x, y, z);
      const botPos = bot.entity?.position;
      const isPlacingAtOwnPosition = !!botPos
        && Math.floor(botPos.x) === x
        && Math.floor(botPos.y) === y
        && Math.floor(botPos.z) === z;
      const blockAtPos = bot.blockAt(placePos);

      if (blockAtPos && blockAtPos.name !== 'air') {
        return factory.createResponse(`There's already a block (${blockAtPos.name}) at (${x}, ${y}, ${z})`);
      }

      // 置けそうな面を候補として順番に試す
      // - ブロック設置には近接する参照ブロック（隣接）が必要になることが多い
      // - possibleFaces は優先度順に並んでおり、faceDirection によって順序を入れ替えます
      const possibleFaces: FaceOption[] = [
        { direction: 'down', vector: new Vec3(0, -1, 0) },
        { direction: 'north', vector: new Vec3(0, 0, -1) },
        { direction: 'south', vector: new Vec3(0, 0, 1) },
        { direction: 'east', vector: new Vec3(1, 0, 0) },
        { direction: 'west', vector: new Vec3(-1, 0, 0) },
        { direction: 'up', vector: new Vec3(0, 1, 0) }
      ];

      if (faceDirection !== 'down') {
        const specificFace = possibleFaces.find(face => face.direction === faceDirection);
        if (specificFace) {
          possibleFaces.unshift(possibleFaces.splice(possibleFaces.indexOf(specificFace), 1)[0]);
        }
      }

      for (const face of possibleFaces) {
        const referencePos = placePos.plus(face.vector);
        const referenceBlock = bot.blockAt(referencePos);

        if (referenceBlock && referenceBlock.name !== 'air') {
          if (!bot.canSeeBlock(referenceBlock)) {
            const goal = new goals.GoalNear(referencePos.x, referencePos.y, referencePos.z, 2);
            await bot.pathfinder.goto(goal);
          }

          await bot.lookAt(placePos, true);

          try {
            // 自分自身の位置に置く場合はジャンプして高さを確保する（設置判定回避）
            if (isPlacingAtOwnPosition) {
              try { bot.setControlState('jump', true); } catch (_err) { void _err; }
              await new Promise(resolve => setTimeout(resolve, 120));
            }
            await bot.placeBlock(referenceBlock, face.vector.scaled(-1));
            return factory.createResponse(`Placed block at (${x}, ${y}, ${z}) using ${face.direction} face`);
          } catch (placeError) {
            // 設置失敗は別の面で試す。ログは残すがエラーは直ちに返さない
            log('warn', `Failed to place using ${face.direction} face: ${placeError}`);
            continue;
          } finally {
            if (isPlacingAtOwnPosition) {
              try { bot.setControlState('jump', false); } catch (_err) { void _err; }
            }
          }
        }
      }

      return factory.createResponse(`Failed to place block at (${x}, ${y}, ${z}): No suitable reference block found`);
    }
  );

  // 指定位置のブロックを掘るツール
  factory.registerTool(
    "dig-block",
    "Dig a block at the specified position",
    {
      x: z.coerce.number().describe("X coordinate"),
      y: z.coerce.number().describe("Y coordinate"),
      z: z.coerce.number().describe("Z coordinate"),
    },
    async ({ x, y, z }) => {
      ({ x, y, z } = coerceCoordinates(x, y, z));

      const bot = getBot();
      const blockPos = new Vec3(x, y, z);
      const block = bot.blockAt(blockPos);

      if (!block || block.name === 'air') {
        return factory.createResponse(`No block found at position (${x}, ${y}, ${z})`);
      }

      if (!bot.canDigBlock(block) || !bot.canSeeBlock(block)) {
        const goal = new goals.GoalNear(x, y, z, 2);
        await bot.pathfinder.goto(goal);
      }

      await bot.dig(block);
      return factory.createResponse(`Dug ${block.name} at (${x}, ${y}, ${z})`);
    }
  );

  // 指定アイテムを装備してブロックを掘るツール（装備は戻さない）
  factory.registerTool(
    "dig-block-with-item",
    "Dig a block at the specified position using a specific item from inventory",
    {
      x: z.coerce.number().describe("X coordinate"),
      y: z.coerce.number().describe("Y coordinate"),
      z: z.coerce.number().describe("Z coordinate"),
      item: z.string().describe("Tool/item name to use for digging (partial match allowed)"),
      allowPathDig: z.boolean().optional().default(false).describe("Whether to allow pathfinder to dig blocks during pathfinding (default: false)"),
      timeoutMs: z.number().int().min(50).optional().default(15000).describe("Timeout for pathfinding in ms")
    },
    async ({ x, y, z, item, allowPathDig = false, timeoutMs = 15000 }: { x: number; y: number; z: number; item: string; allowPathDig?: boolean; timeoutMs?: number }) => {
      ({ x, y, z } = coerceCoordinates(x, y, z));

      const bot = getBot();
      const blockPos = new Vec3(x, y, z);
      let block = bot.blockAt(blockPos);

      if (!block || block.name === 'air') {
        return factory.createResponse(`No block found at position (${x}, ${y}, ${z})`);
      }

      // インベントリからアイテムを検索（小文字で正規化、部分一致可）
      const inventory = bot.inventory.items();
      const itemNormalized = item.toLowerCase().replace(/\s+/g, '_');
      const itemStack = inventory.find((it) => {
        const itemName = String(it.name).toLowerCase().replace(/\s+/g, '_');
        return itemName === itemNormalized || itemName.includes(itemNormalized);
      });

      if (!itemStack) {
        return factory.createErrorResponse(`Fail: Item '${item}' not found in inventory`);
      }

      // 装備（掘削後に元に戻さない）
      try {
        await bot.equip(itemStack, 'hand');
      } catch (err) {
        return factory.createErrorResponse(`Fail: Cannot equip item: ${(err as Error).message}`);
      }

      const needPath = !bot.canDigBlock(block) || !bot.canSeeBlock(block);
      const movements = bot.pathfinder.movements;
      const originalCanDig = movements ? movements.canDig : undefined;

      let timeoutId: ReturnType<typeof setTimeout> | null = null;
      let timedOut = false;
      let gotoPromise: Promise<unknown> | null = null;

      try {
        if (needPath) {
          if (allowPathDig && movements && typeof originalCanDig === 'boolean') {
            movements.canDig = true;
          }

          const goal = new goals.GoalNear(x, y, z, 2);
          if (timeoutMs !== undefined) {
            timeoutId = setTimeout(() => {
              timedOut = true;
            }, timeoutMs);
          }

          const pendingGoto = bot.pathfinder.goto(goal);
          if (!pendingGoto) {
            throw new Error('Pathfinder failed to start movement');
          }
          gotoPromise = pendingGoto;
          await gotoPromise;

          if (timedOut) {
            return factory.createErrorResponse(`Fail: Move timed out after ${timeoutMs}ms`);
          }
        }

        // 最新のブロック情報を取得
        block = bot.blockAt(blockPos);
        if (!block || block.name === 'air') {
          return factory.createResponse(`No block found at position (${x}, ${y}, ${z})`);
        }

        await bot.lookAt(block.position, true);
        await bot.dig(block);

        return factory.createResponse(`Dug ${block.name} at (${x}, ${y}, ${z}) with ${item}`);
      } catch (err) {
        return factory.createErrorResponse(`Fail: Dig error: ${(err as Error).message}`);
      } finally {
        if (timeoutId) clearTimeout(timeoutId);
        if (timedOut) {
          try { bot.pathfinder.stop(); } catch (_err) { void _err; }
        }
        if (movements && typeof originalCanDig === 'boolean' && allowPathDig) {
          movements.canDig = originalCanDig;
        }
        if (gotoPromise) gotoPromise.catch(() => {});
      }
    }
  );

  // ブロック情報を取得するツール
  factory.registerTool(
    "get-block-info",
    "Get information about a block at the specified position",
    {
      x: z.coerce.number().describe("X coordinate"),
      y: z.coerce.number().describe("Y coordinate"),
      z: z.coerce.number().describe("Z coordinate"),
    },
    async ({ x, y, z }) => {
      ({ x, y, z } = coerceCoordinates(x, y, z));

      const bot = getBot();
      const blockPos = new Vec3(x, y, z);
      const block = bot.blockAt(blockPos);

      if (!block) {
        return factory.createResponse(`No block information found at position (${x}, ${y}, ${z})`);
      }

      return factory.createResponse(`Found ${block.name} (type: ${block.type}) at position (${block.position.x}, ${block.position.y}, ${block.position.z})`);
    }
  );

  // 指定タイプの最寄りブロックを探すツール
  factory.registerTool(
    "find-block",
    "Find the nearest block of a specific type",
    {
      blockType: z.string().describe("Type of block to find"),
      maxDistance: z.coerce.number().finite().optional().describe("Maximum search distance (default: 16)")
    },
    async ({ blockType, maxDistance = 16 }) => {
      const bot = getBot();
      const mcData = minecraftData(bot.version);
      const blocksByName = mcData.blocksByName;

      if (!blocksByName[blockType]) {
        return factory.createResponse(`Unknown block type: ${blockType}`);
      }

      const blockId = blocksByName[blockType].id;

      const block = bot.findBlock({
        matching: blockId,
        maxDistance: maxDistance
      });

      if (!block) {
        return factory.createResponse(`No ${blockType} found within ${maxDistance} blocks`);
      }

      return factory.createResponse(`Found ${blockType} at position (${block.position.x}, ${block.position.y}, ${block.position.z})`);
    }
  );

  // 周辺を立方体でスキャンしてブロックデータを JSON で返すツール
  factory.registerTool(
    "scan-nearby-blocks",
    "Scan a cubic region around a position and return block data as JSON",
    {
      size: z.coerce.number().int().min(1).optional().describe('Side length of cube to scan (default: 5)'),
      x: z.coerce.number().optional().describe('Center X coordinate (defaults to bot position)'),
      y: z.coerce.number().optional().describe('Center Y coordinate (defaults to bot position)'),
      z: z.coerce.number().optional().describe('Center Z coordinate (defaults to bot position)')
    },
    async ({ size = 5, x, y, z }: { size?: number; x?: number; y?: number; z?: number }) => {
      const bot = getBot();

      let centerX: number;
      let centerY: number;
      let centerZ: number;

      if (typeof x === 'number' && typeof y === 'number' && typeof z === 'number') {
        ({ x: centerX, y: centerY, z: centerZ } = coerceCoordinates(x, y, z));
      } else {
        if (!bot?.entity || !bot.entity.position) {
          throw new Error('Bot position is not available; please provide x,y,z');
        }
        centerX = Math.floor(bot.entity.position.x);
        centerY = Math.floor(bot.entity.position.y);
        centerZ = Math.floor(bot.entity.position.z);
      }

      const side = Math.max(1, Math.trunc(Number(size)));
      const half = Math.floor(side / 2);
      const startX = Math.floor(centerX) - half;
      const startY = Math.floor(centerY) - half;
      const startZ = Math.floor(centerZ) - half;

      const blocks: Array<{ x: number; y: number; z: number; name: string | null; type: number | null }> = [];

      for (let xi = startX; xi < startX + side; xi++) {
        for (let yi = startY; yi < startY + side; yi++) {
          for (let zi = startZ; zi < startZ + side; zi++) {
            try {
              const b = bot.blockAt(new Vec3(xi, yi, zi));
              if (b) {
                blocks.push({ x: xi, y: yi, z: zi, name: b.name ?? null, type: b.type ?? null });
              } else {
                blocks.push({ x: xi, y: yi, z: zi, name: null, type: null });
              }
            } catch (err) {
              blocks.push({ x: xi, y: yi, z: zi, name: null, type: null });
            }
          }
        }
      }

      const result = {
        center: { x: centerX, y: centerY, z: centerZ },
        size: side,
        total: blocks.length,
        blocks
      };

      return factory.createResponse(JSON.stringify(result, null, 2));
    }
  );
}
